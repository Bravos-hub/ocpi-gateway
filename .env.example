SERVICE_NAME=ocpi-gateway
PORT=3003
DATABASE_URL=postgres://postgres:postgres@localhost:5432/evzone
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ocpi-gateway
KAFKA_GROUP_ID=ocpi-gateway
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ocpi
OCPI_BASE_URL_CPO=http://localhost:3003/ocpi/cpo/2.2.1
OCPI_BASE_URL_EMSP=http://localhost:3003/ocpi/emsp/2.2.1
OCPI_BASE_URL_HUB=http://localhost:3003/ocpi/hub/2.2.1
OCPI_PARTY_ID=EVZ
OCPI_COUNTRY_CODE=US
OCPI_BUSINESS_NAME=EVzone
OCPI_TIME_ZONE=UTC
OCPI_DEFAULT_CONNECTOR_STANDARD=IEC_62196_T2
OCPI_DEFAULT_CONNECTOR_FORMAT=SOCKET
OCPI_DEFAULT_CONNECTOR_POWER_TYPE=AC_3_PHASE
OCPI_DEFAULT_CONNECTOR_VOLTAGE=400
OCPI_DEFAULT_CONNECTOR_AMPERAGE=32
OCPI_OUTBOUND_TIMEOUT_MS=5000
OCPI_OUTBOUND_RETRY_MAX=3
OCPI_CREDENTIALS_TOKEN_ENCODING=BASE64
OCPI_ACCEPT_PLAIN_CREDENTIALS_TOKEN=true
OCPI_REQUIRE_ROUTING_HEADERS=false
OCPI_ENABLE_MODULE_COMMANDS=true
OCPI_ENABLE_MODULE_CHARGINGPROFILES=true
OCPI_ENABLE_MODULE_HUBCLIENTINFO=true
EVZONE_BACKEND_URL=https://api.evzonecharging.com
EVZONE_BACKEND_TOKEN_PATH=/auth/service/token
EVZONE_SERVICE_CLIENT_ID=ocpi-gateway
EVZONE_SERVICE_CLIENT_SECRET=change-me
EVZONE_SERVICE_SCOPES="ocpi:read ocpi:write ocpi:commands"
EVZONE_BACKEND_TIMEOUT_MS=5000
